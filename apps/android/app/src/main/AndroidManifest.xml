<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Keep the socket alive while only the keyboard is on screen. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- Show the "connected" status notification (Android 13+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Same APK runs on phones and Android TV. Neither a touchscreen nor
         leanback is required, so the app installs on both form factors. -->
    <uses-feature
        android:name="android.software.leanback"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:banner="@drawable/banner"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Ripple">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Ripple">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <!-- Phone launcher -->
                <category android:name="android.intent.category.LAUNCHER" />
                <!-- TV launcher (leanback) -->
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The Ripple keyboard (IME). -->
        <service
            android:name=".ime.RippleImeService"
            android:label="@string/ime_label"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

        <!-- Keeps the one shared socket alive for the app + keyboard. -->
        <service
            android:name=".RippleConnectionService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
    </application>
</manifest>
